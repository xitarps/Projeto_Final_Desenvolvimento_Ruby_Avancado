<h1>Reports</h1>

<p>
  <%= form_with model: false, url: csv_reports_path do |f| %>
    <%= f.submit 'Generate Products CSV Report' %>
  <% end %>
  <span>
    In case of generating one new report, it may take a while... take some coffe and refresh the page from time to time :)
  </span>
</p>

<% @reports.each do |report| %>
  <%= link_to report.id, csv_report_path(report) %><br>
<% end %>
